# Plantilla de secrets — copiar a secrets.toml y rellenar.
# En Streamlit Cloud: pegar estos valores en Settings → Secrets.
TELEGRAM_TOKEN    = "123456:ABC-tu-token-de-botfather"
TELEGRAM_CHAT_ID  = "123456789"
TELEGRAM_GROUP_ID = "-100xxxxxxxxxx"
GEMINI_API_KEY    = "AIza..."
ANTHROPIC_API_KEY = "sk-ant-..."   # opcional: vacío = solo Gemini
ETHERSCAN_API_KEY = "..."

# Usuarios con acceso a la terminal.
# El valor es el SHA-256 de la contraseña. Para generarlo:
#   python -c "import hashlib; print(hashlib.sha256('MiClave'.encode()).hexdigest())"
# Si esta sección no existe, la app queda abierta (modo desarrollo).
[usuarios]
usuario1 = "<sha256-de-su-contraseña>"
usuario2 = "<sha256-de-su-contraseña>"
usuario3 = "<sha256-de-su-contraseña>"
